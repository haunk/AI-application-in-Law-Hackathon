   "source": [
    "def translate_vn_to_en_sea(vietnamese_text, max_new_tokens=512):\n",
    "    prompt = f\"\"\"<|im_start|>system\n",
    "You are a legal document translator. Translate the following Vietnamese legal text to English accurately.\n",
    "Preserve all legal terminology, section numbers, and article references exactly.\n",
    "<|im_end|>\n",
    "<|im_start|>user\n",
    "Translate this Vietnamese legal text to English:\n",
    "\n",
    "{vietnamese_text}\n",
    "<|im_end|>\n",
    "<|im_start|>assistant\n",
    "\"\"\"\n",
    "    model.to(\"cuda\")\n",
    "    inputs = tokenizer(prompt, return_tensors=\"pt\").to(\"cuda\")\n",
    "\n",
    "    with torch.no_grad():\n",
    "        outputs = model.generate(\n",
    "            **inputs,\n",
    "            max_new_tokens=max_new_tokens,\n",
    "            temperature=0.1,\n",
    "            do_sample=True,\n",
    "            repetition_penalty=1.1,\n",
    "            pad_token_id=tokenizer.eos_token_id\n",
    "        )\n",
    "\n",
    "    # ← KEY FIX: slice off input tokens, decode only new generated tokens\n",
    "    input_length = inputs[\"input_ids\"].shape[1]\n",
    "    new_tokens = outputs[0][input_length:]\n",
    "    result = tokenizer.decode(new_tokens, skip_special_tokens=True)\n",
    "\n",
    "    return result.strip()"
   ]
  },
